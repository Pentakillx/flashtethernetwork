# Telegram Bot Bildirimleri
# Kurulum:
#   1. Telegram'da @BotFather'a yaz → /newbot → bir isim ver → TOKEN'ı kopyala
#   2. Bota bir mesaj at, sonra şu URL'i aç:
#      https://api.telegram.org/bot<TOKEN>/getUpdates
#      "chat":{"id": XXXXX} satırındaki sayı senin CHAT_ID'n
#   3. Bu değerleri .env.local'e yapıştır ve sunucuyu yeniden başlat
TELEGRAM_BOT_TOKEN=123456789:ABCDEFabcdef...
TELEGRAM_CHAT_ID=123456789
